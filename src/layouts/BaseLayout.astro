---
import "../styles/tokens.css";
import "../styles/site.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import BuzzWidget from "../components/BuzzWidget.astro";
import { business } from "../data/business.ts";

interface Props {
  title: string;
  description: string;
  /** Optional path-style OG image; falls back to logo. */
  ogImage?: string;
  /** Optional page-specific JSON-LD objects. */
  extraSchema?: Record<string, unknown> | Record<string, unknown>[];
  /** Hide utility pages such as thank-you and 404 pages from search results. */
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = "/assets/logo-full.png",
  extraSchema = [],
  noindex = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? business.url).toString();
const absoluteOgImage = new URL(ogImage, Astro.site ?? business.url).toString();
const schemaExtras = Array.isArray(extraSchema) ? extraSchema : [extraSchema];

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": ["EducationalOrganization", "LocalBusiness"],
  "@id": `${business.url}/#organization`,
  name: business.name,
  image: absoluteOgImage,
  url: `${business.url}/`,
  telephone: business.phoneDisplay,
  email: business.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: business.city,
    addressRegion: business.region,
    addressCountry: business.country,
  },
  areaServed: business.areaServed.map((area) => ({
    "@type": area.includes("County") ? "AdministrativeArea" : "City",
    name: area,
  })),
  founder: {
    "@type": "Person",
    name: business.owner,
    jobTitle: "Tutor / Certified Educator",
  },
  serviceType: business.serviceTypes,
  description: business.description,
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${business.url}/#website`,
  name: business.name,
  url: `${business.url}/`,
  publisher: { "@id": `${business.url}/#organization` },
  inLanguage: "en-US",
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonical}#webpage`,
  url: canonical,
  name: title,
  description,
  isPartOf: { "@id": `${business.url}/#website` },
  about: { "@id": `${business.url}/#organization` },
  inLanguage: "en-US",
};

const schema = [organizationSchema, websiteSchema, webPageSchema, ...schemaExtras];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:site_name" content={business.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Favicon (placeholder uses logo png; replace with a proper favicon set) -->
    <link rel="icon" href="/assets/character-lemon.svg" type="image/svg+xml" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <meta name="theme-color" content="#FFF8EC" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <BuzzWidget />
  </body>
</html>
