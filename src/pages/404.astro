---
import BaseLayout from "../layouts/BaseLayout.astro";
import Character from "../components/Character.astro";

const title = "Page not found — Gifted to Grow Tutoring";
const description = "We couldn't find that page. Let's get you back to where you were going.";
---
<BaseLayout title={title} description={description}>
  <section class="section-cream" style="padding:96px 0;">
    <div class="shell" style="text-align:center;max-width:560px;">
      <Character kind="orange" size={140} />
      <h1 class="display" style="margin-top:16px;">This page wandered off.</h1>
      <p class="lead">
        That's all right. Even good readers lose the page sometimes.
        Let's try one of these:
      </p>
      <p style="margin-top:24px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/contact/">Send Jennifer a note</a>
      </p>
    </div>
  </section>
</BaseLayout>
