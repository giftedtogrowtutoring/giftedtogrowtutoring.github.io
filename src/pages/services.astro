---
import BaseLayout from "../layouts/BaseLayout.astro";
import Deco from "../components/Deco.astro";
import JoinTheGarden from "../components/JoinTheGarden.astro";

const title = "K–6 Reading, Writing & Math Tutoring | Sarasota & Bradenton";
const description = "Private, semi-private, and small-group K–6 reading, writing, math, and homeschool tutoring for Sarasota and Bradenton families.";

const parentFaqs = [
  {
    question: "Do you offer tutoring in Sarasota and Bradenton?",
    answer:
      "Yes. Gifted to Grow Tutoring supports K–6 families in Sarasota, Bradenton, and nearby communities. Tutoring is currently offered in person only.",
  },
  {
    question: "What grade levels do you tutor?",
    answer: "Jennifer focuses on K–6 students so tutoring can stay developmentally appropriate for elementary learners.",
  },
  {
    question: "Do you offer reading tutoring?",
    answer:
      "Yes. Reading tutoring may include phonics, fluency, vocabulary, comprehension, and confidence-building based on your child’s needs.",
  },
  {
    question: "Do you offer math and writing tutoring?",
    answer:
      "Yes. Jennifer supports K–6 math, writing, spelling, sentence and paragraph development, number sense, and problem solving.",
  },
  {
    question: "Do you work with homeschool families?",
    answer:
      "Yes. Homeschool support can supplement your curriculum, fill skill gaps, or provide a steady second teacher voice for reading, writing, or math.",
  },
  {
    question: "How is pricing determined?",
    answer:
      "Pricing uses a consultative approach. Cost is determined based on consultation, including your child’s needs, format, cadence, and group size.",
  },
  {
    question: "How long are sessions?",
    answer: "Both 60-minute and 30-minute sessions are available.",
  },
  {
    question: "How do parents receive progress updates?",
    answer:
      "Parents receive quarterly progress reports, and Jennifer is available for progress updates at a parent’s request.",
  },
  {
    question: "How quickly will I hear back?",
    answer: "Jennifer will respond within 48 hours.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: parentFaqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const services = [
  {
    name: "1:1 Private Tutoring",
    rate: "Consultative approach",
    per: "60-minute and 30-minute sessions available · Cost determined by consultation",
    bullets: [
      "Fully personalized to your child",
      "Reading, writing, math, or test prep",
      "In-home or in my workspace",
    ],
    feature: true,
  },
  {
    name: "2:1 Semi-Private",
    rate: "Consultative approach",
    per: "60-minute sessions available · Cost determined by consultation",
    bullets: [
      "Two siblings or close friends",
      "Same grade band recommended",
      "Shared format, same teacher",
    ],
  },
  {
    name: "Small Group (3–4 students)",
    rate: "Consultative approach",
    per: "60-minute sessions available · Cost determined by consultation",
    bullets: [
      "Reading or math focus",
      "Limited cohorts each season",
      "Great for homeschool co-ops",
    ],
  },
];
---
<BaseLayout title={title} description={description} extraSchema={faqSchema}>
  <section class="section-cream" style="padding-top:64px;">
    <Deco name="vine" class="scatter" style="bottom:0;right:0;width:50%;opacity:0.45;transform:scaleX(-1);" />
    <div class="shell">
      <div class="eyebrow-row">
        <span class="dot"></span>
        <span class="eyebrow">Tend the Roots</span>
      </div>
      <h1 class="display" style="max-width:18ch;">Tutoring that fits your child, not the other way around.</h1>
      <p class="lead" style="max-width:36em;">
        Every session is built around the child in front of me. Below are the most common ways
        we work together — but if none of these quite fit, send me a note and we'll figure it out.
      </p>
    </div>
  </section>

  <section class="section-cream" style="padding-top:24px;">
    <div class="shell">
      <div class="pricing">
        {services.map((s) => (
          <div class={`price${s.feature ? " feature" : ""}`}>
            <h3 style={s.feature ? "color:var(--plum);" : ""}>{s.name}</h3>
            <div class="rate">{s.rate}</div>
            <div class="per" style={s.feature ? "color:var(--plum);" : ""}>{s.per}</div>
            <ul>
              {s.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <p style="margin-top:18px;font-size:14px;color:var(--ink-soft);">
        Consultative approach: Cost is determined based on consultation.
      </p>
      <p class="hand hand--green" style="margin-top:32px;text-align:center;font-size:1.75rem;">
        "Free 15-minute consultation call to find the right fit."
      </p>
      <article class="svc path-anxious" style="max-width:760px;margin:24px auto 0;">
        <span class="icon" aria-hidden="true">✎</span>
        <h2>For accepted and scheduled tutoring students</h2>
        <p>If your child has already been accepted and placed on Jennifer’s tutoring schedule, please complete the separate Established Tutoring Student Intake Form before the first session.</p>
        <p>This onboarding form confirms the schedule previously arranged with Jennifer and is not a tutoring inquiry, consultation, availability, or booking request.</p>
        <p><a class="btn btn-secondary" href="/tutoring-student-intake/">Complete Student Intake</a></p>
      </article>

    </div>
  </section>

  <section class="section-cream" style="padding-top:24px;">
    <div class="shell">
      <article class="svc path-homeschool" style="max-width:760px;margin:0 auto;">
        <span class="icon" aria-hidden="true"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/></svg></span>
        <h2>Homeschool Support Services</h2>
        <p>Personalized homeschool support for Bradenton and Sarasota families, including curriculum guidance, scheduling support, academic insight, tutoring support, and in-person Florida portfolio evaluations.</p>
        <p><strong>Pricing is provided on a consultative basis.</strong> Recommendations and pricing are based on your family’s individual needs.</p>
        <p><a class="btn btn-primary" href="/homeschool-support/">Explore Homeschool Support</a></p>
      </article>
    </div>
  </section>

  <section class="section-lavender">
    <div class="shell">
      <div class="two-col">
        <div>
          <div class="eyebrow-row">
            <span class="dot"></span>
            <span class="eyebrow">Homeschool partnership</span>
          </div>
          <h2>Help that fits beside your curriculum.</h2>
          <p>
            If you're homeschooling, I won't try to replace what you're doing. I'll come alongside it —
            shoring up reading fluency, untangling a tricky math concept, or giving your child a steady
            second teacher voice. We design the cadence together.
          </p>
          <p><strong>Consultative approach:</strong> Cost is determined after we talk through your child’s needs, cadence, and group size.</p>
        </div>
        <div>
          <div class="eyebrow-row">
            <span class="dot"></span>
            <span class="eyebrow">FL Step Up scholarship</span>
          </div>
          <h2>Accepted, with no out-of-pocket for qualifying families.</h2>
          <p>
            I'm a registered <strong>FL Step Up for Students Provider</strong>. If your family qualifies
            for a scholarship, tutoring is covered — bring me the paperwork and I'll walk you through it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-cream">
    <div class="shell">
      <div class="section-head center">
        <h2>How a first session usually goes.</h2>
      </div>
      <ol style="max-width:620px;margin:0 auto;padding-left:24px;font-size:1.0625rem;line-height:1.7;color:var(--ink);">
        <li><strong>The free intro call (15 min).</strong> You tell me about your child. I listen, take notes, and tell you honestly whether I'm the right fit.</li>
        <li><strong>The first session.</strong> We meet in person — at your home or my workspace. The first 10 minutes are about getting comfortable. Then we start with something they already know, so they leave proud.</li>
        <li><strong>Ongoing rhythm.</strong> Most families settle into one or two sessions a week. Parents receive quarterly progress reports, and progress updates are always available at a parent’s request.</li>
      </ol>
    </div>
  </section>

  <section class="section-lavender">
    <div class="shell">
      <div class="section-head center">
        <div class="eyebrow-row">
          <span class="dot"></span>
          <span class="eyebrow">Parent questions</span>
        </div>
        <h2>Quick answers for Sarasota and Bradenton families.</h2>
        <p class="lead">
          A simple place to confirm the essentials before you reach out about private tutoring,
          small-group tutoring, reading, writing, math, or homeschool support.
        </p>
      </div>

      <div class="faq-grid" itemscope itemtype="https://schema.org/FAQPage">
        {parentFaqs.map((faq) => (
          <article class="card faq-card" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 itemprop="name">{faq.question}</h3>
            <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{faq.answer}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <JoinTheGarden />
</BaseLayout>
