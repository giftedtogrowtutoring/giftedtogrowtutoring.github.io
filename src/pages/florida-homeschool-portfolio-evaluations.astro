---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Florida Homeschool Portfolio Evaluations | Gifted To Grow Tutoring";
const description = "In-person Florida homeschool portfolio evaluations are now part of Gifted To Grow Tutoring's Homeschool Support Services for Bradenton and Sarasota families.";
---
<BaseLayout title={title} description={description} noindex={true}>
  <section class="section-cream" style="padding-top:64px;">
    <div class="shell shell-narrow" style="text-align:center;">
      <div class="eyebrow-row" style="justify-content:center;"><span class="dot"></span><span class="eyebrow">Homeschool support</span></div>
      <h1>Florida Homeschool Portfolio Evaluations</h1>
      <p class="lead">Portfolio evaluations are now included on the Homeschool Support Services page.</p>
      <p>Evaluations are held in person by appointment in the Bradenton/Sarasota area. Portfolio evaluation pricing is provided on a consultative basis.</p>
      <a class="btn btn-primary" href="/portfolio-evaluation-intake/">Request a Portfolio Evaluation</a>
    </div>
  </section>
</BaseLayout>
