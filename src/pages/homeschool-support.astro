---
import BaseLayout from "../layouts/BaseLayout.astro";
import Deco from "../components/Deco.astro";
import Character from "../components/Character.astro";
import { business } from "../data/business.ts";

const title = "Homeschool Support Services | Gifted To Grow Tutoring";
const description = "Personalized homeschool consulting, curriculum guidance, scheduling support, tutoring, and in-person Florida portfolio evaluations for families in the Bradenton and Sarasota area.";
const WEB3FORMS_ACCESS_KEY = "040e27de-957a-4362-9f43-a0dcc796dec9";

const services = [
  { value: "Homeschool Family Consultation", title: "Homeschool Family Consultation", desc: "Personalized consultations for families who are beginning homeschooling, making changes to their current approach, or looking for guidance and reassurance.", includes: ["Discussing family goals and concerns", "Reviewing the child’s current educational needs", "Exploring homeschool options", "Answering general homeschool planning questions", "Identifying appropriate next steps", "Creating a personalized support plan"], button: "Inquire About a Homeschool Consultation", pricing: "Pricing is provided on a consultative basis based on your family’s individual needs." },
  { value: "Curriculum Guidance and Selection", title: "Curriculum Guidance and Selection", desc: "Individualized guidance to help families choose, evaluate, or adjust curriculum based on the child’s learning needs, academic level, strengths, challenges, and family goals.", includes: ["Reviewing current curriculum", "Helping families compare curriculum options", "Identifying curriculum that fits the child’s learning style", "Recommending subject-specific resources", "Helping families avoid unnecessary curriculum purchases", "Adjusting curriculum when the current program is not working", "Identifying supplemental materials"], button: "Inquire About Curriculum Support", pricing: "Curriculum recommendations and pricing are provided on a consultative basis." },
  { value: "Homeschool Scheduling and Planning Support", title: "Homeschool Scheduling and Planning Support", desc: "Practical support for creating a homeschool schedule that fits the child, the family’s routines, and the parent’s goals.", includes: ["Creating daily or weekly schedules", "Building flexible routines", "Planning subject rotations", "Balancing academics with activities", "Adjusting schedules for multiple children", "Helping families create realistic expectations", "Developing short-term or long-term learning plans"], button: "Inquire About Scheduling Support", pricing: "Scheduling and planning support is customized, with pricing provided after an initial consultation." },
  { value: "Academic Needs Consultation", title: "Academic Needs Consultation", desc: "Support for parents who want a clearer understanding of their child’s strengths, academic needs, instructional level, or areas where additional support may be helpful.", includes: ["Parent consultation", "Review of work samples", "Discussion of academic strengths", "Identification of areas for growth", "Recommendations for tutoring or supplemental support", "Guidance about appropriate next steps"], button: "Inquire About Academic Support", pricing: "Recommendations and pricing are provided on a consultative basis based on the level of support requested." },
];
const bringItems = ["Samples of your child's work from throughout the year", "Reading list or books completed", "Writing samples", "Math work", "Projects, artwork, or science activities, if applicable", "Photos of field trips or hands-on learning experiences, optional"];
const features = ["Florida-certified teacher", "Experienced educator", "Personalized guidance for each family", "One-on-one support", "Encouraging and family-friendly approach", "In-person homeschool portfolio evaluations", "Curriculum and planning support", "Convenient consultation requests"];
const formServices = [...services.map((s) => s.value), "Tutoring Support", "Not Sure Yet — I Need Guidance", "Other"];
---
<BaseLayout title={title} description={description}>
  <section class="section-cream homeschool-hero" style="padding-top:64px;">
    <Deco name="vine" class="scatter" style="bottom:0;right:0;width:50%;opacity:0.42;transform:scaleX(-1);" />
    <Deco name="book" class="scatter" style="top:48px;right:8%;width:74px;transform:rotate(12deg);" />
    <div class="shell">
      <div class="eyebrow-row"><span class="dot"></span><span class="eyebrow">Homeschool support</span></div>
      <h1 class="display" style="max-width:15ch;">Homeschool Support Services</h1>
      <p class="lead" style="max-width:34em;"><strong>Personalized Guidance for Homeschool Families</strong></p>
      <p class="lead" style="max-width:44em;">At Gifted To Grow Tutoring, homeschool families receive personalized support designed around the needs of each child and family. Whether you need help choosing curriculum, creating a manageable schedule, understanding your child’s academic needs, or completing an annual homeschool portfolio evaluation, I am here to provide knowledgeable and encouraging guidance.</p>
      <a class="btn btn-primary" href="#homeschool-intake">Request a Consultation</a>
    </div>
  </section>

  <section class="section-lavender">
    <div class="shell"><div class="section-head center"><h2>Personalized homeschool consulting services</h2><p class="lead">Each service is customized and consultative, so recommendations fit your family instead of forcing you into a preset package.</p></div>
      <div class="homeschool-service-grid">
        {services.map((service) => <article class="svc path-homeschool homeschool-card"><h3>{service.title}</h3><p>{service.desc}</p><ul>{service.includes.map((item) => <li>{item}</li>)}</ul><p class="pricing-note"><strong>{service.pricing}</strong></p><a class="btn btn-secondary service-inquiry" href={`/homeschool-support/?service=${encodeURIComponent(service.value)}#homeschool-intake`}>{service.button}</a></article>)}
      </div>
    </div>
  </section>

  <section class="section-cream" id="portfolio-evaluations">
    <div class="shell"><article class="card portfolio-feature"><div><div class="eyebrow-row"><span class="dot"></span><span class="eyebrow">Annual Homeschool Evaluations for Florida Families</span></div><h2>Florida Homeschool Portfolio Evaluations</h2><p>As a Florida-certified teacher and owner of Gifted To Grow Tutoring, I provide professional annual homeschool portfolio evaluations in a relaxed, encouraging environment. My goal is to make this required step simple, stress-free, and even enjoyable for your family.</p><h3>What to Expect</h3><p>During our in-person meeting, we'll review your child's homeschool portfolio, discuss the learning and growth that has taken place throughout the year, and celebrate their accomplishments.</p><p>Once the evaluation is complete, I'll provide you with a signed evaluation letter for submission to your Florida school district.</p><h3>Meeting Location</h3><p><strong>Evaluations are held in person by appointment in the Bradenton/Sarasota area.</strong></p><h3>Evaluation Pricing</h3><p>Portfolio evaluation pricing is provided on a consultative basis. Contact Gifted To Grow Tutoring for personalized information based on your family’s needs.</p><a class="btn btn-primary service-inquiry" href="/portfolio-evaluation-intake/">Request a Portfolio Evaluation</a></div><div><h3>Please Bring</h3><div class="check-card-grid compact">{bringItems.map((item) => <div class="check-card"><span class="check-icon" aria-hidden="true">✓</span><p>{item}</p></div>)}</div><p class="portfolio-reassurance hand hand--green">Don't worry if your portfolio isn't perfectly organized—I'll guide you through the process!</p></div></article></div>
  </section>

  <section class="section-lavender"><div class="shell"><div class="section-head center"><h2>Why Choose Gifted To Grow?</h2></div><div class="feature-card-grid">{features.map((feature) => <article class="svc path-homeschool"><span class="icon" aria-hidden="true">✦</span><h3>{feature}</h3></article>)}</div></div></section>

  <section class="section-cream" id="homeschool-intake"><div class="shell shell-narrow"><div class="section-head center"><h2>Homeschool Family Intake Form</h2><p class="lead">Tell me a little about your family and the support you are looking for. This information will help me prepare for our conversation and recommend the most appropriate next steps.</p><p class="pricing-note"><strong>Services are customized to each family. Recommendations and pricing will be discussed after reviewing your needs.</strong></p></div>
    <form id="homeschoolForm" class="card homeschool-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} /><input type="hidden" name="subject" value="Homeschool family intake — Gifted to Grow" /><input type="hidden" name="from_name" value="giftedtogrowtutoring.com" /><input type="hidden" name="redirect" value={`${business.url}/thanks/`} /><input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none;visibility:hidden;" />
      <h3>Parent or Guardian Information</h3><div class="field-row"><div class="field"><label for="parentName">Parent/Guardian Name *</label><input id="parentName" name="parent_guardian_name" required autocomplete="name" /></div><div class="field"><label for="email">Email Address *</label><input id="email" name="email" type="email" required autocomplete="email" /></div></div><div class="field-row"><div class="field"><label for="phone">Phone Number *</label><input id="phone" name="phone" type="tel" required autocomplete="tel" pattern="^[0-9+().\-\s]{7,}$" /></div><div class="field"><label for="contactMethod">Preferred Contact Method *</label><select id="contactMethod" name="preferred_contact_method" required><option value="">Choose one</option><option>Phone</option><option>Email</option><option>Text</option></select></div></div>
      <h3>Family Information</h3><div class="field-row"><div class="field"><label for="city">City *</label><input id="city" name="city" required /></div><div class="field"><label for="county">County *</label><input id="county" name="county" required /></div></div><div class="field"><label for="childrenCount">Number of Children Needing Support *</label><input id="childrenCount" name="number_of_children_needing_support" type="number" min="1" required /></div>
      <fieldset class="field"><legend>Service Requested *</legend><div class="checkbox-grid">{formServices.map((service) => <label class="checkbox-row"><input type="checkbox" name="services_requested[]" value={service} data-service={service} /> {service}</label>)}</div><p class="helper">You may choose more than one service.</p></fieldset>
      <h3>Student Information</h3><div class="field-row"><div class="field"><label for="studentName">Student Name *</label><input id="studentName" name="student_name" required /></div><div class="field"><label for="age">Age *</label><input id="age" name="student_age" type="number" min="1" required /></div></div><div class="field-row"><div class="field"><label for="dob">Date of Birth <span>(optional unless needed for evaluation)</span></label><input id="dob" name="student_date_of_birth" type="date" /></div><div class="field"><label for="gradeLevel">Current Grade or Approximate Grade Level *</label><input id="gradeLevel" name="grade_level" required /></div></div><div class="field-row"><div class="field"><label for="yearsHomeschooled">Years Homeschooled</label><input id="yearsHomeschooled" name="years_homeschooled" /></div><div class="field"><label for="subjects">Subjects Needing Support</label><input id="subjects" name="subjects_needing_support" /></div></div><div class="field"><label for="currentCurriculum">Current Curriculum, if applicable</label><input id="currentCurriculum" name="current_curriculum" /></div><div class="field"><label for="strengths">Learning Strengths</label><textarea id="strengths" name="learning_strengths"></textarea></div><div class="field"><label for="concerns">Areas of Concern</label><textarea id="concerns" name="areas_of_concern"></textarea></div><div class="field"><label for="additionalStudents">Additional children or relevant student information</label><textarea id="additionalStudents" name="additional_children_information" placeholder="If more than one child needs support, please share each child’s name, age, grade level, subjects, and anything helpful to know."></textarea></div>
      <div class="conditional-field" data-show-when="Curriculum Guidance and Selection"><h3>Curriculum Support Questions</h3>{["What curriculum are you currently using?", "What is working well?", "What is not working well?", "Are you looking for a complete curriculum, subject-specific curriculum, or supplemental materials?", "Are there any curriculum styles or approaches you prefer or want to avoid?", "What are your main curriculum goals?"].map((q) => <div class="field"><label>{q}</label><textarea aria-label={q} name={`curriculum_${q.toLowerCase().replace(/[^a-z0-9]+/g, "_")}`}></textarea></div>)}</div>
      <div class="conditional-field" data-show-when="Homeschool Scheduling and Planning Support"><h3>Scheduling and Planning Questions</h3>{["What does your current homeschool schedule or routine look like?", "What scheduling challenges are you experiencing?", "How many children are being homeschooled?", "Are you seeking a daily schedule, weekly schedule, long-term plan, or general routine guidance?", "What activities or commitments need to be considered?"].map((q) => <div class="field"><label>{q}</label><textarea aria-label={q} name={`schedule_${q.toLowerCase().replace(/[^a-z0-9]+/g, "_")}`}></textarea></div>)}</div>
      <h3>Academic Needs Questions</h3>{["What subjects does your child enjoy most?", "Which subjects are most challenging?", "What are your primary academic concerns?", "Are you interested in tutoring support?", "What would you most like your child to improve?"].map((q) => <div class="field"><label>{q}</label><textarea aria-label={q} name={`academic_${q.toLowerCase().replace(/[^a-z0-9]+/g, "_")}`}></textarea></div>)}
      <h3>Family Goals</h3><div class="field"><label for="goals">What are your main goals for your child or homeschool this year?</label><textarea id="goals" name="family_goals"></textarea></div><div class="field"><label for="proud">What are you most proud of in your child’s progress?</label><textarea id="proud" name="child_progress_proud_of"></textarea></div><div class="field"><label for="anythingElse">Is there anything else you would like me to know before our consultation?</label><textarea id="anythingElse" name="anything_else"></textarea></div>
      <h3>Consultation Preferences</h3><div class="field-row"><div class="field"><label>Preferred consultation date</label><input aria-label="Preferred consultation date" name="preferred_consultation_date" type="date" /></div><div class="field"><label>Preferred consultation time</label><input aria-label="Preferred consultation time" name="preferred_consultation_time" type="time" /></div></div><div class="field-row"><div class="field"><label>Preferred communication method</label><select aria-label="Preferred communication method" name="consultation_communication_method"><option value="">Choose one</option><option>Phone</option><option>Email</option><option>Text</option></select></div><div class="field conditional-consult"><label>In-person or phone consultation preference</label><select aria-label="In-person or phone consultation preference" name="consultation_location_preference"><option value="">Choose one</option><option>In-person consultation</option><option>Phone consultation</option></select></div></div>
      <div class="form-status" aria-live="polite"></div><button id="homeschoolSubmit" type="submit" class="btn btn-primary">Request My Homeschool Consultation</button>
    </form></div></section>
  <section class="section-lavender" style="padding:56px 0;"><div class="shell" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:12px;"><Character kind="lemon" size={70} /><p style="max-width:34em;margin:0;color:var(--ink-soft);">Thank you for sharing information about your family. Gifted To Grow Tutoring will review your request and follow up to discuss your needs, service options, and next steps.</p></div></section>
  <script>
    const form = document.getElementById("homeschoolForm");
    const params = new URLSearchParams(window.location.search);
    const requested = params.get("service");
    const checkboxes = Array.from(document.querySelectorAll("[data-service]"));
    const submit = document.getElementById("homeschoolSubmit");
    const updateConditional = () => {
      const selected = checkboxes.filter((box) => box instanceof HTMLInputElement && box.checked).map((box) => box.value);
      document.querySelectorAll("[data-show-when]").forEach((section) => {
        const show = selected.includes(section.getAttribute("data-show-when") || "");
        section.toggleAttribute("hidden", !show);
      });
      if (submit) submit.textContent = "Request My Homeschool Consultation";
    };
    if (requested) { const option = checkboxes.find((box) => box.value === requested); if (option instanceof HTMLInputElement) option.checked = true; }
    checkboxes.forEach((box) => box.addEventListener("change", updateConditional));
    updateConditional();
    form?.addEventListener("submit", (event) => {
      if (!checkboxes.some((box) => box instanceof HTMLInputElement && box.checked)) { event.preventDefault(); const status = form.querySelector(".form-status"); if (status) status.textContent = "Please select at least one homeschool service."; }
      else if (submit instanceof HTMLButtonElement) { submit.disabled = true; submit.textContent = "Sending…"; }
    });
  </script>
</BaseLayout>
