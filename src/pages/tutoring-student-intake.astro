---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Current or Accepted Tutoring Students | Gifted To Grow Tutoring";
const description = "Redirect to the Current or Accepted Tutoring Students onboarding form.";
---
<BaseLayout title={title} description={description}>
  <section class="section-cream" style="padding-top:64px;">
    <div class="shell shell-narrow card" style="text-align:center;">
      <h1>Current or Accepted Tutoring Students</h1>
      <p>This form now has its own website destination.</p>
      <p><a class="btn btn-primary" href="/current-or-accepted-tutoring-students/">Continue to the New Student Welcome &amp; Partnership Form</a></p>
    </div>
  </section>
  <script is:inline>
    window.location.replace('/current-or-accepted-tutoring-students/');
  </script>
</BaseLayout>
