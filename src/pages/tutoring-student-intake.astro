---
import BaseLayout from "../layouts/BaseLayout.astro";
import Deco from "../components/Deco.astro";
import { business } from "../data/business.ts";

const title = "New Tutoring Student Welcome & Partnership Form | Gifted To Grow Tutoring";
const description = "Concise welcome intake, tutoring partnership agreement, cancellation policy acknowledgment, and electronic signature for accepted and scheduled Gifted To Grow Tutoring students.";
const WEB3FORMS_ACCESS_KEY = "040e27de-957a-4362-9f43-a0dcc796dec9";
const POLICY_VERSION = "GTG-PARTNERSHIP-CANCELLATION-v2";
const FORM_VERSION = "GTG-TUTORING-INTAKE-v2";
const tutoringFocus = ["Reading", "Writing", "Math", "Homework Help", "FAST Testing Practice", "Florida State Testing Practice", "General Academic Support", "Other"];
const supportAreas = ["Foundational skill development", "Targeted help with specific skills", "Catching up academically", "Homework support", "Test preparation", "Extra practice and review", "Building confidence", "Hands-on learning", "Enrichment or additional challenge", "Other"];
const learningPreferences = ["Hands-on activities", "Visual examples", "Verbal explanation", "Movement", "Repetition and practice", "Games", "A mixture of approaches", "Not sure"];
const commitments = ["Meet your child where they are academically", "Recognize and build upon your child’s strengths and gifts", "Tailor tutoring to your child’s individual learning needs", "Use hands-on, visual, verbal, and other learning approaches when appropriate", "Address specific areas of academic need", "Encourage confidence, perseverance, and growth", "Prepare for each scheduled session", "Communicate honestly and respectfully with parents", "Share meaningful observations about progress and concerns", "Partner with the classroom teacher when appropriate and authorized", "Treat your child with patience, dignity, and encouragement", "Respect your family’s time"];
const familyRoles = ["Support consistent attendance", "Communicate directly and promptly about concerns or schedule changes", "Share information that may help Jennifer understand and support the child", "Encourage the child to participate and arrive ready to learn", "Inform Jennifer of important classroom goals, assignments, or teacher feedback", "Understand that academic growth takes time, consistency, and practice", "Ask questions and communicate openly when something is not working", "Work collaboratively toward the child’s individual goals", "Respect the tutoring time reserved specifically for the child"];
const policySummary = ["More than 24 hours’ notice and direct communication: No cancellation fee", "Less than 24 hours’ notice: 50% of the scheduled session fee", "Three cancellations or reschedules within any rolling 90-day period: The third occurrence is charged at 100%", "No-show: 100% of the scheduled session fee", "Genuine illness and family emergencies: Contact Jennifer directly; circumstances may be reviewed individually", "If Jennifer cancels within 24 hours: The next scheduled session receives a 50% discount", "Frequent scheduling changes may require a review of the reserved tutoring time"];
---
<BaseLayout title={title} description={description}>
  <section class="section-cream intake-page" style="padding-top:64px;">
    <Deco name="pencil" class="scatter" style="top:34px;right:7%;width:72px;transform:rotate(18deg);" />
    <div class="shell shell-narrow">
      <div class="eyebrow-row"><span class="dot"></span><span class="eyebrow">New tutoring families</span></div>
      <h1 class="display">New Tutoring Student Welcome &amp; Partnership Form</h1>
      <div class="card intake-notice">
        <p class="completion-time"><strong>Estimated completion time: 10 minutes</strong></p>
        <p>Welcome to Gifted To Grow Tutoring! I am excited to partner with your family and support your child’s academic growth.</p>
        <p>This form is for students who have already been accepted and scheduled for tutoring. It should take approximately 10 minutes to complete. The information you provide will help me understand your child’s strengths, needs, interests, learning style, and tutoring goals before our first session.</p>
        <p class="notice-box"><strong>If your child has not yet been accepted and scheduled for tutoring, please contact Jennifer before completing this form.</strong></p>
        <a class="btn btn-secondary" href="/contact/">Interested in Tutoring? Contact Jennifer</a>
      </div>

      <form id="studentIntakeForm" class="card homeschool-form intake-form" action="https://api.web3forms.com/submit" method="POST" novalidate>
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" id="emailSubject" value="New Tutoring Student Intake" data-prefix="New Tutoring Student Intake — " />
        <input type="hidden" name="form_type" value="New Tutoring Student Welcome & Partnership Form" />
        <input type="hidden" name="form_version" value={FORM_VERSION} />
        <input type="hidden" name="policy_version" value={POLICY_VERSION} />
        <input type="hidden" name="submission_timestamp" id="submissionTimestamp" value="" />
        <input type="hidden" name="from_name" value="giftedtogrowtutoring.com" />
        <input type="hidden" name="redirect" value={`${business.url}/thanks/?form=tutoring-student-intake`} />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none;visibility:hidden;" />

        <div id="formErrors" class="form-status" role="alert" aria-live="assertive"></div>
        <fieldset class="field status-check"><legend>Student status confirmation *</legend><label class="checkbox-row"><input id="acceptedStatus" name="accepted_and_scheduled_confirmation" type="checkbox" required value="Confirmed: child has already been accepted and scheduled" data-message="This form is only for students who have already been accepted and scheduled. Please contact Jennifer first if you are still asking about tutoring availability." /> I confirm that my child has already been accepted and scheduled for tutoring with Gifted To Grow Tutoring.</label><p class="field-error" id="acceptedStatus-error"></p></fieldset>

        <section class="form-card"><h2>Parent or Guardian Information</h2><div class="field-row"><div class="field"><label for="parentName">Parent/Guardian Name *</label><input id="parentName" name="parent_guardian_name" required autocomplete="name" /></div><div class="field"><label for="email">Email Address *</label><input id="email" name="email" type="email" required autocomplete="email" /></div></div><div class="field-row"><div class="field"><label for="phone">Phone Number *</label><input id="phone" name="phone" type="tel" required autocomplete="tel" pattern="^[0-9+().\-\s]{7,}$" /></div><div class="field"><label for="contactMethod">Preferred Contact Method *</label><select id="contactMethod" name="preferred_contact_method" required><option value="">Choose one</option><option>Text</option><option>Phone</option><option>Email</option></select></div></div><div class="field"><label for="bestTime">Best time to contact <span>(optional)</span></label><input id="bestTime" name="best_time_to_contact" /></div></section>

        <section class="form-card"><h2>Student Information</h2><p class="helper">Gifted To Grow Tutoring currently serves students in grades K–6.</p><div class="field-row"><div class="field"><label for="studentName">Student Name *</label><input id="studentName" name="student_name" required /></div><div class="field"><label for="preferredName">Preferred Name or Nickname <span>(optional)</span></label><input id="preferredName" name="student_preferred_name" /></div></div><div class="field-row"><div class="field"><label for="grade">Current Grade *</label><select id="grade" name="current_grade" required><option value="">Choose one</option><option>Kindergarten</option><option>Grade 1</option><option>Grade 2</option><option>Grade 3</option><option>Grade 4</option><option>Grade 5</option><option>Grade 6</option></select></div><div class="field"><label for="school">School Name <span>(optional)</span></label><input id="school" name="school_name" /></div></div><div class="field"><label for="teacher">Classroom Teacher <span>(optional)</span></label><input id="teacher" name="classroom_teacher" /></div></section>

        <section class="form-card"><h2>Confirmed Tutoring Schedule</h2><p class="helper">Please enter the tutoring schedule previously confirmed with Jennifer.</p><div class="field-row"><div class="field"><label for="day">Confirmed Tutoring Day *</label><input id="day" name="confirmed_tutoring_day" required /></div><div class="field"><label for="time">Confirmed Tutoring Time *</label><input id="time" name="confirmed_tutoring_time" required /></div></div><div class="field-row"><div class="field"><label for="startDate">Tutoring Start Date *</label><input id="startDate" name="tutoring_start_date" type="date" required /></div><div class="field"><label for="frequency">Expected Frequency *</label><select id="frequency" name="expected_frequency" required><option value="">Choose one</option><option>Once per week</option><option>Twice per week</option><option>Other</option></select></div></div></section>

        <section class="form-card"><h2>Tutoring Needs</h2><fieldset class="field" data-required-group="tutoring_focus"><legend>Tutoring Focus *</legend><div class="checkbox-grid">{tutoringFocus.map((item) => <label class="checkbox-row"><input type="checkbox" name="tutoring_focus[]" value={item} data-other-toggle={item === "Other" ? "focusOther" : undefined} /> {item}</label>)}</div><p class="field-error"></p></fieldset><div class="field conditional" id="focusOther"><label for="focusOtherText">Other tutoring focus</label><input id="focusOtherText" name="other_tutoring_focus" /></div><fieldset class="field" data-required-group="areas_of_support"><legend>Areas of Support *</legend><div class="checkbox-grid">{supportAreas.map((item) => <label class="checkbox-row"><input type="checkbox" name="areas_of_support[]" value={item} data-other-toggle={item === "Other" ? "supportOther" : undefined} /> {item}</label>)}</div><p class="field-error"></p></fieldset><div class="field conditional" id="supportOther"><label for="supportOtherText">Other area of support</label><input id="supportOtherText" name="other_area_of_support" /></div></section>

        <section class="form-card"><h2>Understanding the Child</h2><div class="field"><label for="strengths">What are your child’s greatest academic strengths? *</label><textarea id="strengths" name="academic_strengths" required rows="3"></textarea></div><div class="field"><label for="concerns">What are your primary concerns about your child’s learning? *</label><textarea id="concerns" name="primary_learning_concerns" required rows="3"></textarea></div><div class="field"><label for="goals">What would you most like your child to accomplish through tutoring? *</label><textarea id="goals" name="tutoring_goals" required rows="3"></textarea></div><div class="field main-open-response"><label for="childInfo">Please tell me anything you would like me to know about your child. You may include their personality, interests, frustrations, motivations, school experiences, learning preferences, confidence, or anything else that would help me support them well. *</label><textarea id="childInfo" name="anything_to_know_about_child" required rows="5"></textarea><p class="helper">This is your opportunity to share anything that may help me understand and connect with your child. You do not need to provide private medical records or diagnostic documents.</p></div></section>

        <section class="form-card"><h2>Learning Preferences</h2><fieldset class="field"><legend>Learning preferences</legend><div class="checkbox-grid">{learningPreferences.map((item) => <label class="checkbox-row"><input type="checkbox" name="learning_preferences[]" value={item} /> {item}</label>)}</div></fieldset><div class="field"><label for="engagement">What interests, activities, topics, or rewards help your child stay engaged? <span>(optional)</span></label><input id="engagement" name="engagement_interests_rewards" /></div></section>

        <section class="form-card"><h2>School and Previous Support</h2><fieldset class="field"><legend>Has your child received tutoring before?</legend><label class="checkbox-row"><input type="radio" name="previous_tutoring" value="Yes" /> Yes</label><label class="checkbox-row"><input type="radio" name="previous_tutoring" value="No" /> No</label></fieldset><div class="field"><label for="iep504">Does your child currently have an IEP, 504 Plan, or school intervention plan? <span>(optional)</span></label><select id="iep504" name="iep_504_or_intervention_plan"><option value="">Choose one</option><option>Yes</option><option>No</option><option>Prefer not to answer</option></select></div><div class="field"><label for="schoolSupport">Please share any teacher feedback, school concerns, accommodations, learning strategies, recent testing information, or previous tutoring experiences that may help me support your child. <span>(optional)</span></label><textarea id="schoolSupport" name="school_and_previous_support_notes" rows="4"></textarea></div></section>

        <section class="form-card agreement-card"><h2>Gifted To Grow Tutoring Partnership Agreement</h2><p>Thank you for choosing Gifted To Grow Tutoring.</p><p>I believe tutoring is most effective when it is built on trust, communication, consistency, and partnership. My role is not simply to complete assignments with your child. My goal is to meet your child where they are, recognize their unique gifts and abilities, and provide instruction tailored to their academic needs and learning style.</p><p>Every child learns differently. Tutoring sessions may include targeted skill instruction, hands-on learning, guided practice, academic review, encouragement, and strategies designed specifically for your child.</p><p>The strongest progress happens when the tutor, parent or guardian, student, and, when appropriate, classroom teacher work together as an educational team.</p><h3>My Commitment to Your Child and Family</h3><ul class="check-list">{commitments.map((item) => <li>{item}</li>)}</ul><h3>The Family’s Role in the Partnership</h3><ul class="check-list">{familyRoles.map((item) => <li>{item}</li>)}</ul><h3>Communication and Collaboration</h3><p>I want parents to feel comfortable communicating with me. If you have a concern, question, schedule issue, or new information about your child, please contact me directly.</p><p>When appropriate and with parent permission, I am also willing to communicate with your child’s classroom teacher so that tutoring can support current classroom goals and needs.</p><p>Our shared purpose is to help your child grow academically, build confidence, and recognize the gifts and abilities they already possess.</p><h3>Educational Philosophy</h3><p>At Gifted To Grow Tutoring, every child is viewed as uniquely gifted and capable of growth. Tutoring is tailored to the child rather than expecting every child to learn in exactly the same way.</p><p>My goal is to provide instruction with patience, encouragement, honesty, compassion, and respect. I believe families and educators accomplish more when we work together with a shared commitment to the child.</p>
        <div class="policy-section"><h2>Attendance, Scheduling, and Cancellation Policy</h2><p>Consistent attendance is an important part of a child’s academic progress. Each tutoring time is reserved specifically for one student, and regular attendance allows each session to build on the last.</p><p>I also understand that life happens. Children get sick, parents get sick, injuries occur, family emergencies arise, and unexpected circumstances are sometimes unavoidable. I want families to feel comfortable contacting me directly so we can discuss what is happening.</p><p>I will always approach genuine illness and family emergencies with empathy, compassion, and fairness. At the same time, the following policy is necessary to protect reserved tutoring time, support consistency for students, and maintain a dependable schedule for all families.</p><h3>More Than 24 Hours’ Notice</h3><p>If you need to cancel or reschedule a tutoring session, please contact Jennifer directly as soon as possible.</p><p>When more than 24 hours’ notice is provided, there is no cancellation fee as long as the parent or guardian contacts Jennifer directly to discuss the cancellation or possible rescheduling.</p><h3>Less Than 24 Hours’ Notice</h3><p>Cancellations or rescheduling requests made less than 24 hours before the scheduled tutoring session will be charged 50% of the scheduled session fee.</p><h3>Rolling 90-Day Cancellation Period</h3><p>To support consistency and protect each student’s reserved tutoring time, cancellations and rescheduling requests are tracked within a rolling 90-day period.</p><p>A rolling 90-day period means that on the date of any cancellation or rescheduling request, the previous 90 calendar days are reviewed. This is not based on a school quarter, semester, calendar quarter, or fixed date range.</p><p>Both cancellations and rescheduled sessions count toward the rolling 90-day total, whether they occur with more than or less than 24 hours’ notice.</p><p>If a family has three cancellations or rescheduling requests within any rolling 90-day period, the third occurrence will be charged 100% of the scheduled session fee.</p><p>Any additional cancellations or rescheduling requests that fall within the same rolling 90-day window may also be charged at 100% of the scheduled session fee unless Jennifer and the family have directly discussed and agreed upon a different arrangement.</p><p>As older cancellations move beyond 90 calendar days, they no longer count toward the current rolling 90-day total.</p><p class="example-box"><strong>Example:</strong> If sessions are canceled on January 10, February 5, and March 20, all three fall within a 90-day window. The March 20 cancellation is the third occurrence and may be charged at the full session fee. Once the January 10 cancellation becomes more than 90 calendar days old, it no longer counts toward the current total.</p><h3>Illnesses, Emergencies, and Direct Communication</h3><p>I understand that illnesses, injuries, family emergencies, and unexpected situations are part of life.</p><p>If your child is sick, someone in your household becomes ill, or your family experiences an emergency, please contact Jennifer directly as soon as you are able.</p><p>Every situation is unique. Jennifer will listen, communicate with the family, and work with parents whenever reasonably possible. Genuine emergencies may be reviewed individually with compassion and understanding.</p><p>This flexibility does not eliminate the need for a clear policy. Repeated cancellations, even when understandable, can interrupt a child’s progress and prevent the reserved tutoring time from being offered to another family. Repeated scheduling difficulties may therefore require a conversation about whether the current day, time, or ongoing tutoring arrangement remains the best fit.</p><p class="notice-box"><strong>This policy is not intended to discourage families from communicating about genuine illness or emergencies. Direct and timely communication is always encouraged.</strong></p><h3>No-Show Policy</h3><p>If a student does not attend a scheduled tutoring session and Jennifer has not received communication before the session begins, the appointment will be considered a no-show and will be charged at 100% of the scheduled session fee.</p><h3>Jennifer’s Reciprocal Commitment</h3><p>Respect, communication, and flexibility should go both ways.</p><p>If Jennifer cancels a tutoring session with less than 24 hours’ notice because of illness, a family emergency, or another unavoidable circumstance, the family’s next scheduled tutoring session will receive a 50% discount.</p><p>Jennifer will also communicate directly with the family as soon as reasonably possible.</p><h3>Schedule Review</h3><p>Frequent cancellations or rescheduling requests may result in a conversation about whether the currently reserved tutoring day and time remain workable for the family.</p><p>When possible, Jennifer will work with the family to identify a more appropriate arrangement. However, continued inconsistency may result in the reserved time being released so that another student can use it.</p><h3>Policy Purpose</h3><p>This policy exists to support children through consistent instruction, protect time reserved for each student, maintain fairness among families, and create a tutoring relationship built on communication, empathy, dependability, and mutual respect.</p></div></section>

        <section class="form-card summary-card"><h2>Quick Policy Summary</h2><p class="helper">The summary does not replace the complete policy.</p><ul class="check-list">{policySummary.map((item) => <li>{item}</li>)}</ul></section>

        <section class="form-card signature-card"><h2>Parent/Guardian Partnership Agreement</h2><p>By signing below, I acknowledge that I have read and understand the Gifted To Grow Tutoring Partnership Agreement and the Attendance, Scheduling, and Cancellation Policy.</p><p>I understand that tutoring is a partnership involving Jennifer, my child, me as the parent or guardian, and, when appropriate and authorized, my child’s teacher.</p><p>I agree to communicate openly, support consistent attendance, share relevant educational information, and work collaboratively toward my child’s academic goals.</p><p>I understand that Gifted To Grow Tutoring will provide individualized instruction based on my child’s needs, gifts, abilities, and learning style, but that specific grades, test scores, academic outcomes, or rates of progress cannot be guaranteed.</p><p>I understand the rolling 90-day cancellation policy and agree to the charges and procedures described in the policy.</p><fieldset class="field"><legend>Required acknowledgments *</legend>{[["agreement_accepted_scheduled", "I confirm that my child has already been accepted and scheduled for tutoring."], ["agreement_partnership", "I have read, understand, and agree to the Gifted To Grow Tutoring Partnership Agreement."], ["agreement_cancellation_policy", "I have read, understand, and agree to the Attendance, Scheduling, and Cancellation Policy."], ["agreement_rolling_90_day", "I understand that three cancellations or rescheduling requests within any rolling 90-day period will result in the third occurrence being charged at 100% of the scheduled session fee."], ["agreement_emergency_policy", "I understand that genuine illnesses and family emergencies may be discussed directly with Jennifer, but that direct communication does not automatically waive the cancellation policy."]].map(([name, label]) => <label class="checkbox-row"><input type="checkbox" name={name} value="Acknowledged" required /> {label}</label>)}</fieldset><p class="helper">By typing my name below, I understand that I am providing my electronic signature and agreeing to the terms stated above.</p><div class="field-row"><div class="field"><label for="legalName">Parent/Guardian Full Legal Name *</label><input id="legalName" name="parent_guardian_full_legal_name" required autocomplete="name" /></div><div class="field"><label for="signature">Electronic Signature *</label><input id="signature" name="electronic_signature" required /></div></div><div class="field"><label for="signatureDate">Date Signed *</label><input id="signatureDate" name="date_signed" type="date" required /></div></section>

        <div class="form-status" id="submitStatus" aria-live="polite"></div><button id="studentIntakeSubmit" type="submit" class="btn btn-primary">Submit Student Intake &amp; Partnership Agreement</button>
      </form>
    </div>
  </section>
  <script>
    const form = document.getElementById("studentIntakeForm");
    const submit = document.getElementById("studentIntakeSubmit");
    const formErrors = document.getElementById("formErrors");
    const studentName = document.getElementById("studentName");
    const emailSubject = document.getElementById("emailSubject");
    const timestamp = document.getElementById("submissionTimestamp");
    const showConditional = () => document.querySelectorAll("[data-other-toggle]").forEach((box) => { const target = document.getElementById(box.getAttribute("data-other-toggle") || ""); if (target) target.classList.toggle("is-visible", box.checked); });
    document.querySelectorAll("[data-other-toggle]").forEach((box) => box.addEventListener("change", showConditional));
    showConditional();
    studentName?.addEventListener("input", () => { if (emailSubject instanceof HTMLInputElement && studentName instanceof HTMLInputElement) emailSubject.value = `${emailSubject.dataset.prefix}${studentName.value.trim() || "Student Name"}`; });
    form?.addEventListener("submit", (event) => {
      if (!(form instanceof HTMLFormElement)) return;
      form.querySelectorAll(".field-error").forEach((el) => { el.textContent = ""; });
      if (formErrors) formErrors.textContent = "";
      let firstInvalid = null;
      const setInvalid = (el, message) => { if (!firstInvalid) firstInvalid = el; const field = el.closest(".field, fieldset"); const err = field?.querySelector(".field-error"); if (err) err.textContent = message; };
      form.querySelectorAll("[data-required-group]").forEach((group) => { if (!group.querySelector("input[type='checkbox']:checked")) setInvalid(group, "Please select at least one option."); });
      const accepted = document.getElementById("acceptedStatus");
      if (accepted instanceof HTMLInputElement && !accepted.checked) setInvalid(accepted, accepted.dataset.message || "Please complete this required checkbox.");
      if (!form.checkValidity() || firstInvalid) {
        event.preventDefault();
        if (formErrors) formErrors.textContent = "Please review the highlighted required fields before submitting.";
        (firstInvalid || form.querySelector(":invalid"))?.focus();
        return;
      }
      if (timestamp instanceof HTMLInputElement) timestamp.value = new Date().toISOString();
      if (submit instanceof HTMLButtonElement) { submit.disabled = true; submit.textContent = "Submitting…"; }
    });
  </script>
</BaseLayout>
