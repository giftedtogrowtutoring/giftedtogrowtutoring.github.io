---
import BaseLayout from "../layouts/BaseLayout.astro";
import Deco from "../components/Deco.astro";
import { business } from "../data/business.ts";

const title = "Tutoring Student Intake | Gifted To Grow Tutoring";
const description = "Established Tutoring Student Intake Form for families whose child has already been accepted and scheduled for tutoring with Gifted To Grow Tutoring.";
const WEB3FORMS_ACCESS_KEY = "040e27de-957a-4362-9f43-a0dcc796dec9";
const subjects = ["Reading", "Writing", "Math", "Homework Help", "FAST Testing Practice", "Florida State Testing Practice", "General Academic Support", "Other"];
const goals = ["Strengthen foundational skills", "Close academic gaps", "Improve reading fluency", "Improve reading comprehension", "Improve phonics or decoding", "Improve writing skills", "Improve spelling", "Improve math facts", "Improve math concepts", "Improve problem-solving", "Receive homework support", "Prepare for FAST testing", "Prepare for state testing", "Build confidence", "Improve focus or work habits", "Receive enrichment", "Other"];
const readingSkills = ["Letter recognition", "Letter sounds", "Phonemic awareness", "Phonics", "Decoding", "Sight words", "Fluency", "Vocabulary", "Comprehension", "Confidence", "Other"];
const writingSkills = ["Handwriting", "Letter formation", "Spelling", "Complete sentences", "Grammar", "Punctuation", "Paragraph development", "Organizing ideas", "Written expression", "Editing", "Confidence", "Other"];
const mathSkills = ["Number recognition", "Number sense", "Counting", "Addition", "Subtraction", "Multiplication", "Division", "Math fact fluency", "Place value", "Fractions", "Decimals", "Word problems", "Multi-step problems", "Measurement", "Geometry", "Confidence", "Other"];
const textQuestions = (prefix: string, questions: string[]) => questions.map((q) => ({ q, name: `${prefix}_${q.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "")}` }));
---
<BaseLayout title={title} description={description}>
  <section class="section-cream intake-page" style="padding-top:64px;">
    <Deco name="pencil" class="scatter" style="top:34px;right:7%;width:72px;transform:rotate(18deg);" />
    <div class="shell shell-narrow">
      <div class="eyebrow-row"><span class="dot"></span><span class="eyebrow">New tutoring families</span></div>
      <h1 class="display">Tutoring Student Intake</h1>
      <div class="card intake-notice">
        <h2>Established Tutoring Student Intake Form</h2>
        <p>This form is for families whose child has already been accepted and scheduled for tutoring with Gifted To Grow Tutoring. Please complete it before your child’s first session so I can learn more about their strengths, needs, school experience, and learning goals.</p>
        <p><strong>This form is for students who have already been accepted and scheduled for tutoring.</strong> If you are interested in tutoring but have not yet spoken with Jennifer, please use the general contact form first.</p>
        <a class="btn btn-secondary" href="/contact/">Interested in Tutoring? Contact Jennifer</a>
      </div>

      <form id="studentIntakeForm" class="card homeschool-form intake-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="Established Tutoring Student Intake" />
        <input type="hidden" name="form_type" value="Established Tutoring Student Intake" />
        <input type="hidden" name="from_name" value="giftedtogrowtutoring.com" />
        <input type="hidden" name="redirect" value={`${business.url}/thanks/?form=tutoring-student-intake`} />
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none;visibility:hidden;" />

        <fieldset class="field status-check"><legend>Student status confirmation *</legend><label class="checkbox-row"><input id="acceptedStatus" name="accepted_and_scheduled_confirmation" type="checkbox" required value="Confirmed: child has already been accepted and scheduled" /> I confirm that my child has already been accepted and scheduled for tutoring with Gifted To Grow Tutoring.</label><p id="statusError" class="form-status" aria-live="polite"></p></fieldset>

        <h3>Parent or Guardian Information</h3>
        <div class="field-row"><div class="field"><label for="parentName">Parent/Guardian Name *</label><input id="parentName" name="parent_guardian_name" required autocomplete="name" /></div><div class="field"><label for="email">Email Address *</label><input id="email" name="email" type="email" required autocomplete="email" /></div></div>
        <div class="field-row"><div class="field"><label for="phone">Phone Number *</label><input id="phone" name="phone" type="tel" required autocomplete="tel" pattern="^[0-9+().\-\s]{7,}$" /></div><div class="field"><label for="contactMethod">Preferred Contact Method *</label><select id="contactMethod" name="preferred_contact_method" required><option value="">Choose one</option><option>Phone</option><option>Text</option><option>Email</option></select></div></div>
        <div class="field-row"><div class="field"><label for="bestTime">Best time to contact <span>(optional)</span></label><input id="bestTime" name="best_time_to_contact" /></div><div class="field"><label for="city">Home City *</label><input id="city" name="home_city" required /></div></div>
        <div class="field-row"><div class="field"><label for="emergencyName">Emergency Contact Name</label><input id="emergencyName" name="emergency_contact_name" /></div><div class="field"><label for="emergencyPhone">Emergency Contact Phone Number</label><input id="emergencyPhone" name="emergency_contact_phone" type="tel" /></div></div><div class="field"><label for="emergencyRelationship">Relationship to Student</label><input id="emergencyRelationship" name="emergency_contact_relationship" /></div>

        <h3>Student Information</h3><p class="helper">Gifted To Grow Tutoring serves students in grades K–6.</p>
        <div class="field-row"><div class="field"><label for="studentName">Student Name *</label><input id="studentName" name="student_name" required /></div><div class="field"><label for="preferredName">Preferred Name or Nickname</label><input id="preferredName" name="student_preferred_name" /></div></div>
        <div class="field-row"><div class="field"><label for="age">Age *</label><input id="age" name="student_age" type="number" min="4" max="13" required /></div><div class="field"><label for="dob">Date of Birth *</label><input id="dob" name="student_date_of_birth" type="date" required /></div></div>
        <div class="field-row"><div class="field"><label for="grade">Current Grade *</label><select id="grade" name="current_grade" required><option value="">Choose one</option><option>Kindergarten</option><option>1st grade</option><option>2nd grade</option><option>3rd grade</option><option>4th grade</option><option>5th grade</option><option>6th grade</option></select></div><div class="field"><label for="school">School Name *</label><input id="school" name="school_name" required /></div></div>
        <div class="field-row"><div class="field"><label for="teacher">Teacher Name <span>(optional)</span></label><input id="teacher" name="teacher_name" /></div><div class="field"><label for="district">School District <span>(optional)</span></label><input id="district" name="school_district" /></div></div>

        <h3>Tutoring Schedule Confirmation</h3><p class="helper">Please enter the schedule previously confirmed with Jennifer. These fields confirm the agreed schedule and do not request new availability.</p>
        <div class="field-row"><div class="field"><label for="day">Scheduled Tutoring Day *</label><input id="day" name="scheduled_tutoring_day" required /></div><div class="field"><label for="time">Scheduled Tutoring Time *</label><input id="time" name="scheduled_tutoring_time" required /></div></div>
        <div class="field-row"><div class="field"><label for="startDate">Tutoring Start Date *</label><input id="startDate" name="tutoring_start_date" type="date" required /></div><div class="field"><label for="frequency">Expected Frequency *</label><select id="frequency" name="expected_frequency" required><option value="">Choose one</option><option>Once per week</option><option>Twice per week</option><option>Other</option></select></div></div>
        <div class="field"><label for="locationArrangement">Location or tutoring arrangement *</label><select id="locationArrangement" name="location_or_tutoring_arrangement" required><option value="">Choose confirmed arrangement</option><option>In person at family's home in Sarasota or Bradenton</option><option>In person at Jennifer's workspace</option></select></div>

        <fieldset class="field"><legend>Subjects Being Tutored *</legend><div class="checkbox-grid">{subjects.map((item) => <label class="checkbox-row"><input type="checkbox" name="subjects_being_tutored[]" value={item} data-subject={item} /> {item}</label>)}</div></fieldset>
        <fieldset class="field"><legend>Primary Tutoring Goals</legend><div class="checkbox-grid">{goals.map((item) => <label class="checkbox-row"><input type="checkbox" name="primary_tutoring_goals[]" value={item} /> {item}</label>)}</div></fieldset>
        <div class="field"><label for="mainGoals">What are your main goals for your child’s tutoring?</label><textarea id="mainGoals" name="main_tutoring_goals"></textarea></div>

        <h3>Parent Concerns</h3>{textQuestions("concerns", ["What concerns led you to seek tutoring?", "What does your child find most difficult academically?", "What would you most like to see improve?", "Is there anything that makes learning especially frustrating for your child?", "Is there anything Jennifer should know before the first tutoring session?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}

        <section class="intake-subsection" data-relevant="Reading"><h3>Reading Profile</h3><p class="helper">Complete this section if reading is relevant to tutoring.</p>{textQuestions("reading", ["Does your child know letter names and sounds?", "Does your child struggle with phonemic awareness?", "Does your child struggle with phonics or decoding?", "Does your child recognize common sight words?", "How would you describe your child’s reading fluency?", "How well does your child understand what they read?", "Does your child enjoy reading?", "What books, topics, or characters interest your child?", "Has the school provided a reading level?", "Is your child receiving reading intervention at school?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}<fieldset class="field"><legend>What reading skills are current concerns?</legend><div class="checkbox-grid">{readingSkills.map((item) => <label class="checkbox-row"><input type="checkbox" name="reading_current_concerns[]" value={item} /> {item}</label>)}</div></fieldset></section>
        <section class="intake-subsection" data-relevant="Writing"><h3>Writing Profile</h3><p class="helper">Complete this section if writing is relevant to tutoring.</p>{textQuestions("writing", ["How does your child feel about writing?", "What types of writing are difficult?", "Does your child struggle to get ideas onto paper?", "Does your child struggle with handwriting?", "Does your child struggle with spelling?", "Does your child write complete sentences?", "Does your child organize ideas clearly?", "What writing expectations has the school shared?", "What writing goals are most important?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}<fieldset class="field"><legend>Writing skill concerns</legend><div class="checkbox-grid">{writingSkills.map((item) => <label class="checkbox-row"><input type="checkbox" name="writing_skill_concerns[]" value={item} /> {item}</label>)}</div></fieldset></section>
        <section class="intake-subsection" data-relevant="Math"><h3>Math Profile</h3><p class="helper">Complete this section if math is relevant to tutoring.</p>{textQuestions("math", ["How does your child feel about math?", "What math concepts are most difficult?", "Does your child know basic math facts?", "Does your child struggle with word problems?", "Does your child struggle to explain mathematical thinking?", "What math topics is the class currently covering?", "Has the school shared a current math level or concern?", "What math goals are most important?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}<fieldset class="field"><legend>Math skill concerns</legend><div class="checkbox-grid">{mathSkills.map((item) => <label class="checkbox-row"><input type="checkbox" name="math_skill_concerns[]" value={item} /> {item}</label>)}</div></fieldset></section>
        <section class="intake-subsection" data-relevant="Homework Help"><h3>Homework Help</h3>{textQuestions("homework", ["Which subjects require the most help?", "How often does the child receive homework?", "How long does homework usually take?", "Does the child understand the directions?", "Does the child need help staying focused?", "Does the child need help organizing materials?", "Are assignments completed on paper, online, or both?", "Are there recurring homework challenges Jennifer should know about?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}</section>
        <section class="intake-subsection" data-relevant="FAST Testing Practice,Florida State Testing Practice"><h3>FAST and State Testing</h3><p class="helper">Tutoring may include standards-based skill review, practice with test-style questions, pacing strategies, and confidence-building. Specific scores or testing outcomes cannot be guaranteed.</p><div class="field"><label for="testSubject">Subject being tested</label><select id="testSubject" name="testing_subject"><option value="">Choose one</option><option>Reading</option><option>Math</option><option>Both</option></select></div>{textQuestions("testing", ["Grade level of the upcoming assessment", "Approximate testing date", "Has the child taken the assessment before?", "Are previous score reports available?", "What areas were most difficult?", "Is the goal focused on skill review, question familiarity, pacing, confidence, or a combination?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}</section>

        <h3>School Performance</h3>{textQuestions("school", ["Current grades", "Recent report-card comments", "Teacher concerns", "Recent benchmark or assessment results", "Current intervention or support services", "Accommodations or strategies that help the child"]).map(({ q, name }) => <div class="field"><label>{q} <span>(optional)</span></label><textarea name={name} aria-label={q}></textarea></div>)}<div class="field"><label for="iep504">IEP or 504 Plan <span>(optional)</span></label><select id="iep504" name="iep_or_504_plan"><option value="">Choose one</option><option>Yes</option><option>No</option><option>Prefer not to answer</option></select></div><p class="helper">Please do not upload medical or diagnostic records. Secure file uploads are not enabled on this site; you may bring optional school documents to Jennifer if helpful.</p>
        <h3>Child’s Learning Style and Personality</h3>{textQuestions("learning_style", ["What are your child’s academic strengths?", "What subjects does your child enjoy?", "What interests or hobbies does your child have?", "What motivates your child?", "What tends to discourage or frustrate your child?", "How does your child respond when work is difficult?", "What helps your child regain confidence?", "How long can your child typically focus on one activity?", "Does your child prefer quiet work or interactive instruction?", "Are there rewards, themes, characters, or interests that help with engagement?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}<fieldset class="field"><legend>Does your child prefer:</legend><div class="checkbox-grid">{["Visual learning", "Verbal instruction", "Hands-on activities", "Movement", "Repetition", "Games", "A mixture of approaches"].map((item) => <label class="checkbox-row"><input type="checkbox" name="learning_preferences[]" value={item} /> {item}</label>)}</div></fieldset>
        <h3>Previous Tutoring</h3>{textQuestions("previous_tutoring", ["Has your child received tutoring before?", "What worked well?", "What did not work well?", "Has your child had difficulty connecting with a tutor before?", "Is there anything Jennifer should approach differently?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}
        <h3>Student Confidence and Attitude</h3>{textQuestions("confidence", ["How does your child currently feel about school?", "How does your child feel about the subject being tutored?", "Does your child become anxious, avoidant, frustrated, or discouraged?", "What helps your child feel successful?", "What accomplishments is your child most proud of?"]).map(({ q, name }) => <div class="field"><label>{q}</label><textarea name={name} aria-label={q}></textarea></div>)}
        <h3>Parent Communication Preferences</h3><div class="field-row"><div class="field"><label for="updates">How often would you like progress updates?</label><select id="updates" name="progress_update_frequency"><option value="">Choose one</option><option>After each session</option><option>Weekly</option><option>Every few weeks</option><option>As needed</option></select></div><div class="field"><label for="updateMethod">Preferred update method</label><select id="updateMethod" name="progress_update_method"><option value="">Choose one</option><option>Text</option><option>Email</option><option>Phone</option></select></div></div><div class="field"><label for="regularUpdates">Are there specific skills or assignments you want regular updates about?</label><textarea id="regularUpdates" name="regular_update_topics"></textarea></div><div class="field"><label for="teacherContact">May Jennifer communicate with the child’s classroom teacher if needed?</label><select id="teacherContact" name="teacher_communication_authorization"><option value="">Choose one</option><option>Yes</option><option>No</option><option>Please ask me first</option></select></div><p class="helper">Jennifer will not contact a teacher without appropriate parent authorization.</p>
        <h3>Policies and Acknowledgments</h3><p class="helper">Policy details should be reviewed manually by Jennifer. This form does not create new cancellation, payment, attendance, or refund terms.</p><fieldset class="field"><legend>Please acknowledge:</legend>{["The child has already been accepted and scheduled.", "Schedule changes must follow the business’s existing cancellation or rescheduling policy.", "Tutoring supports academic growth but does not guarantee grades, scores, promotion, or specific outcomes.", "Parents should share relevant school information that may help instruction.", "Completing the form does not change the previously agreed schedule."].map((item) => <label class="checkbox-row"><input type="checkbox" name="policy_acknowledgments[]" value={item} required /> {item}</label>)}</fieldset>
        <h3>Electronic Signature</h3><div class="field-row"><div class="field"><label for="signature">Parent/Guardian Full Name *</label><input id="signature" name="electronic_signature_name" required /></div><div class="field"><label for="signatureDate">Date *</label><input id="signatureDate" name="electronic_signature_date" type="date" required /></div></div><label class="checkbox-row field"><input type="checkbox" name="signature_agreement" required value="I confirm the information is accurate and child is accepted and scheduled" /> I confirm that the information provided is accurate to the best of my knowledge and that my child has already been accepted and scheduled for tutoring with Gifted To Grow Tutoring.</label>
        <div class="form-status" aria-live="polite"></div><button id="studentIntakeSubmit" type="submit" class="btn btn-primary">Submit Student Intake Form</button>
      </form>
    </div>
  </section>
  <script>
    const form = document.getElementById("studentIntakeForm");
    const accepted = document.getElementById("acceptedStatus");
    const statusError = document.getElementById("statusError");
    const submit = document.getElementById("studentIntakeSubmit");
    const subjectChecks = Array.from(document.querySelectorAll("[data-subject]"));
    const updateRelevantSections = () => {
      const selected = subjectChecks.filter((box) => box instanceof HTMLInputElement && box.checked).map((box) => box.value);
      document.querySelectorAll("[data-relevant]").forEach((section) => {
        const values = (section.getAttribute("data-relevant") || "").split(",");
        const isRelevant = values.some((value) => selected.includes(value));
        section.classList.toggle("is-highlighted", isRelevant);
      });
    };
    subjectChecks.forEach((box) => box.addEventListener("change", updateRelevantSections));
    updateRelevantSections();
    form?.addEventListener("submit", (event) => {
      if (!(accepted instanceof HTMLInputElement) || !accepted.checked) {
        event.preventDefault();
        if (statusError) statusError.textContent = "Please confirm your child has already been accepted and scheduled. Families who have not yet been accepted should contact Jennifer first.";
        accepted?.focus();
        return;
      }
      if (!subjectChecks.some((box) => box instanceof HTMLInputElement && box.checked)) {
        event.preventDefault();
        const status = form.querySelector(".form-status:last-of-type");
        if (status) status.textContent = "Please select at least one subject being tutored.";
        return;
      }
      if (submit instanceof HTMLButtonElement) { submit.disabled = true; submit.textContent = "Sending…"; }
    });
  </script>
</BaseLayout>
