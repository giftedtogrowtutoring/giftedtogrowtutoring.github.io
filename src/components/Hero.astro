---
import Deco from "./Deco.astro";
import Character from "./Character.astro";
import AudiencePicker from "./AudiencePicker.astro";
import { business } from "../data/business.ts";
---
<section class="hero">
  <Deco name="sparkle" class="scatter" style="top:80px;left:6%;width:28px;" />
  <Deco name="leaf"    class="scatter" style="top:32px;right:4%;width:80px;transform:rotate(20deg);" />
  <Deco name="seed"    class="scatter" style="bottom:36px;left:10%;width:28px;opacity:0.6;" />

  <div class="shell">
    <div class="hero-inner">
      <div>
        <div class="eyebrow-row">
          <span class="dot"></span>
          <span class="eyebrow">K–6 Reading, Writing &amp; Math · {business.serviceArea}</span>
        </div>
        <h1>
          Reading should feel like a <span class="underline-word">story</span>,<br/>
          not a struggle.
        </h1>
        <p class="lead">
          One certified educator. Twenty-five years in K–6 classrooms.
          Patient, one-on-one tutoring that meets your child exactly where they are.
        </p>

        <div class="hero-cta-row">
          <a class="btn btn-primary" href="/contact/">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Send Jennifer a note
          </a>
          <a href={`tel:${business.phoneTel}`} class="phone-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            or call {business.phoneDisplay}
          </a>
        </div>

        <AudiencePicker />

        <div class="trust-row">
          <span><b>FL Step Up</b> Provider</span>
          <span aria-hidden="true">·</span>
          <span>Certified PreK–6</span>
          <span aria-hidden="true">·</span>
          <span>Reading Endorsed</span>
          <span aria-hidden="true">·</span>
          <span>ESOL Endorsed</span>
        </div>
      </div>

      <div class="hero-character-stage" aria-hidden="true">
        <Deco name="sparkle" class="sparkle-1" breathe />
        <Deco name="sparkle" class="sparkle-2" breathe offset />
        <Deco name="sprout"  class="sprout" />
        <img src="/assets/deco-book.svg" alt="" class="book" loading="eager" />
        <Character kind="lemon"  class="lemon" />
        <Character kind="orange" class="orange" offset />
      </div>
    </div>
  </div>
</section>
