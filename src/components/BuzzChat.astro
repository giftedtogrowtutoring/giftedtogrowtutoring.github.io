---
import { Image } from "astro:assets";
import beeGreeting from "../assets/bee-mascot-greeting.png";
import beeThinking from "../assets/bee-mascot-thinking.png";
import beeWriting from "../assets/bee-mascot-writing.png";
import { suggestedQuestions } from "../data/faq.ts";
---
<div
  id="buzz-chat"
  class="buzz-chat is-closed"
  role="dialog"
  aria-modal="true"
  aria-labelledby="buzz-title"
  aria-hidden="true"
>
  <header class="buzz-chat__header">
    <span class="buzz-chat__avatar-wrap" aria-hidden="true">
      <Image
        src={beeGreeting}
        alt=""
        width={80}
        height={80}
        loading="lazy"
        class="buzz-chat__avatar buzz-chat__avatar--greeting is-active"
      />
      <Image
        src={beeThinking}
        alt=""
        width={80}
        height={80}
        loading="lazy"
        class="buzz-chat__avatar buzz-chat__avatar--thinking"
      />
      <Image
        src={beeWriting}
        alt=""
        width={80}
        height={80}
        loading="lazy"
        class="buzz-chat__avatar buzz-chat__avatar--writing"
      />
    </span>
    <div class="buzz-chat__title-wrap">
      <h2 id="buzz-title" class="buzz-chat__title">Buzz</h2>
      <p class="buzz-chat__subtitle">Jennifer's helper bee</p>
    </div>
    <button
      type="button"
      class="buzz-chat__close"
      id="buzz-close"
      aria-label="Close chat"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" focusable="false">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </header>

  <div class="buzz-chat__messages" id="buzz-messages" role="log" aria-live="polite" aria-atomic="false">
    <div class="buzz-msg buzz-msg--bot">
      <span class="buzz-msg__bubble">
        Hi! I'm Buzz, Jennifer's helper bee. 🐝 Ask me anything about tutoring — or tap a question below to get started.
      </span>
    </div>
    <div class="buzz-suggestions" id="buzz-suggestions" aria-label="Suggested questions">
      {suggestedQuestions.map((q) => (
        <button
          type="button"
          class="buzz-suggestion"
          data-faq-id={q.id}
          data-question={q.question}
        >
          {q.question}
        </button>
      ))}
    </div>
  </div>

  <form class="buzz-chat__form" id="buzz-form" autocomplete="off">
    <label for="buzz-input" class="buzz-chat__visually-hidden">Type your question</label>
    <input
      id="buzz-input"
      type="text"
      placeholder="Type your question…"
      maxlength="200"
      autocomplete="off"
    />
    <button type="submit" class="buzz-chat__send" aria-label="Send">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </form>
</div>

<style>
  .buzz-chat {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: var(--z-overlay);
    width: 380px;
    height: 560px;
    max-height: calc(100vh - 32px);
    background: var(--cream);
    border: 1.5px solid var(--border-soft);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lift);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform-origin: bottom right;
    transition: transform 240ms var(--ease-bounce), opacity 200ms var(--ease-soft);
  }
  .buzz-chat.is-closed {
    opacity: 0;
    transform: scale(0.85) translateY(20px);
    pointer-events: none;
  }
  .buzz-chat.is-open {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* Header */
  .buzz-chat__header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--plum);
    color: var(--cream);
    border-bottom: 1.5px solid var(--plum-deep);
  }
  .buzz-chat__avatar-wrap {
    position: relative;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }
  .buzz-chat__avatar {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    border-radius: 999px;
    background: var(--cream);
    border: 2px solid var(--cream);
    padding: 2px;
    object-fit: contain;
    opacity: 0;
    transition: opacity 240ms var(--ease-soft);
    box-sizing: border-box;
  }
  .buzz-chat__avatar.is-active { opacity: 1; }

  .buzz-chat__title-wrap { flex: 1; min-width: 0; }
  .buzz-chat__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--cream);
    line-height: 1;
    margin: 0 0 2px;
    letter-spacing: -0.005em;
  }
  .buzz-chat__subtitle {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.8125rem;
    color: rgba(255, 248, 236, 0.85);
    margin: 0;
    line-height: 1.2;
  }
  .buzz-chat__close {
    background: transparent;
    border: 0;
    color: var(--cream);
    cursor: pointer;
    padding: 6px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 160ms var(--ease-soft);
  }
  .buzz-chat__close:hover { background: rgba(255, 248, 236, 0.12); }

  /* Messages */
  .buzz-chat__messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scroll-behavior: smooth;
  }
  .buzz-msg {
    display: flex;
    max-width: 88%;
  }
  .buzz-msg--bot { align-self: flex-start; }
  .buzz-msg--user { align-self: flex-end; }
  .buzz-msg__bubble {
    display: inline-block;
    padding: 10px 14px;
    border-radius: var(--r);
    font-size: 0.9375rem;
    line-height: 1.45;
    word-wrap: break-word;
    overflow-wrap: anywhere;
  }
  .buzz-msg--bot .buzz-msg__bubble {
    background: var(--cream-deep);
    color: var(--plum);
    border: 1px solid var(--border-soft);
    border-bottom-left-radius: 6px;
  }
  .buzz-msg--user .buzz-msg__bubble {
    background: var(--plum);
    color: var(--cream);
    border-bottom-right-radius: 6px;
  }
  .buzz-msg__bubble a {
    color: inherit;
    text-decoration-color: var(--lemon);
    font-weight: 700;
  }

  /* Typing dots */
  .buzz-msg--typing .buzz-msg__bubble {
    padding: 12px 16px;
  }
  .buzz-typing-dots {
    display: inline-flex;
    gap: 4px;
    align-items: flex-end;
    height: 12px;
  }
  .buzz-typing-dots span {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--plum-soft);
    animation: buzz-typing 1.2s ease-in-out infinite;
  }
  .buzz-typing-dots span:nth-child(2) { animation-delay: 0.15s; }
  .buzz-typing-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes buzz-typing {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.5; }
    40%           { transform: translateY(-4px); opacity: 1; }
  }

  /* Suggestions */
  .buzz-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .buzz-suggestion {
    background: var(--cream);
    color: var(--plum);
    border: 1.5px solid var(--plum);
    border-radius: var(--r-pill);
    padding: 6px 12px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.8125rem;
    line-height: 1.2;
    cursor: pointer;
    transition: background 160ms var(--ease-soft), transform 160ms var(--ease-soft);
  }
  .buzz-suggestion:hover {
    background: var(--lavender);
    transform: translateY(-1px);
  }

  /* Form */
  .buzz-chat__form {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1.5px solid var(--border-soft);
    background: var(--cream-deep);
  }
  .buzz-chat__form input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--ink);
    background: var(--cream);
    border: 2px solid var(--plum);
    border-radius: var(--r-pill);
    padding: 10px 16px;
    outline: none;
    min-width: 0;
  }
  .buzz-chat__send {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: var(--plum);
    color: var(--cream);
    border: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 160ms var(--ease-soft), transform 160ms var(--ease-soft);
  }
  .buzz-chat__send:hover {
    background: var(--plum-deep);
    transform: translateY(-1px);
  }
  .buzz-chat__send svg { transform: translateX(1px); }

  .buzz-chat__visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Mobile fullscreen */
  @media (max-width: 640px) {
    .buzz-chat {
      right: 0;
      bottom: 0;
      width: 100vw;
      height: 100vh;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      padding-top: env(safe-area-inset-top, 0);
      padding-bottom: env(safe-area-inset-bottom, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .buzz-chat { transition: opacity 200ms linear !important; }
    .buzz-chat.is-closed,
    .buzz-chat.is-open { transform: none; }
    .buzz-typing-dots span { animation: none; opacity: 1; }
    .buzz-chat__messages { scroll-behavior: auto; }
  }
</style>
