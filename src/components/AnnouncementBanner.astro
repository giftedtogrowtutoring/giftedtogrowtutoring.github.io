---
const announcement = "✨ Now Enrolling Tutoring Students for the 2026–2027 School Year • Limited Availability";
const supportingText = "Now accepting new K–6 students for personalized reading, writing, math, homeschool support, and small-group tutoring in Sarasota and Bradenton.";
---
<aside class="announcement-banner" aria-label="Enrollment announcement">
  <div class="shell">
    <div class="announcement-card">
      <p class="announcement-title">{announcement}</p>
      <p class="announcement-copy">{supportingText}</p>
    </div>
  </div>
</aside>
