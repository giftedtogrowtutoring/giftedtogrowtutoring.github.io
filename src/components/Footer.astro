---
import { business } from "../data/business.ts";
const year = new Date().getFullYear();
---
<footer class="site-foot">
  <div class="shell">
    <div class="foot-grid">
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
          <img src="/assets/character-lemon.svg" width="32" height="38" alt="" />
          <span style="font-family:var(--font-display);font-weight:900;font-size:20px;color:var(--plum);">{business.name}</span>
        </div>
        <p style="margin:0;max-width:32em;">
          {business.grades} reading, writing &amp; math tutoring with {business.owner}.
          Serving families in {business.serviceArea}, in person and on Zoom.
        </p>
        <div style="margin-top:16px;display:flex;align-items:center;gap:8px;">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--green);"></span>
          <span style="font-weight:700;color:var(--plum);">FL Step Up for Students Provider</span>
        </div>
      </div>

      <div>
        <h4>Pages</h4>
        <a href="/about/">About Jennifer</a>
        <a href="/approach/">Philosophy</a>
        <a href="/services/">What we do</a>
        <a href="/testimonials/">Stories</a>
        <a href="/contact/">Contact</a>
      </div>

      <div>
        <h4>Reach Jennifer</h4>
        <a href={`tel:${business.phoneTel}`} aria-label={`Call ${business.phoneDisplay}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>{business.phoneDisplay}
        </a>
        <a href={`mailto:${business.email}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>{business.email}
        </a>
        <span style="display:block;margin:4px 0;color:var(--ink-soft);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>{business.serviceArea}
        </span>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© {year} {business.name} · {business.owner}</span>
      <span>Certified PreK–6 · Reading Endorsed · ESOL Endorsed</span>
    </div>
  </div>
</footer>
