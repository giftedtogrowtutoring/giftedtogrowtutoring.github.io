---
import { Image } from "astro:assets";
import beeIdle from "../assets/bee-mascot-idle.png";
---
<button
  type="button"
  id="buzz-launcher"
  class="buzz-launcher is-hidden"
  aria-label="Open chat with Buzz, Jennifer's helper bee"
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-controls="buzz-chat"
>
  <span class="buzz-bubble" aria-hidden="true">
    Got a question<br/>about tutoring?
  </span>

  <span class="buzz-mascot-wrap" aria-hidden="true">
    <Image
      src={beeIdle}
      alt=""
      width={240}
      height={240}
      loading="lazy"
      class="buzz-mascot"
    />
  </span>

  <span class="buzz-pill" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <span class="buzz-pill__text">Click here to ask</span>
    <span class="buzz-pill__arrow">→</span>
  </span>
</button>

<style>
  .buzz-launcher {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: var(--z-widget);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
    transition: opacity 400ms var(--ease-soft), transform 400ms var(--ease-soft);
  }

  .buzz-launcher.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
  }
  .buzz-launcher.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .buzz-launcher.is-wiggle {
    animation: buzz-wiggle 800ms var(--ease-soft) 1;
  }

  @keyframes buzz-wiggle {
    0%   { transform: rotate(0deg); }
    20%  { transform: rotate(-3deg); }
    45%  { transform: rotate(3deg); }
    70%  { transform: rotate(-2deg); }
    88%  { transform: rotate(1deg); }
    100% { transform: rotate(0deg); }
  }

  /* Bubble */
  .buzz-bubble {
    position: relative;
    background: var(--cream);
    color: var(--plum);
    padding: 12px 18px;
    border-radius: 22px 22px 22px 6px;
    border: 1.5px solid var(--sage);
    box-shadow: var(--shadow-lift);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.25;
    text-align: center;
    max-width: 180px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 320ms var(--ease-soft), transform 320ms var(--ease-soft);
  }
  .buzz-bubble::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 0; height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 10px solid var(--cream);
    filter: drop-shadow(0 1px 0 var(--sage));
  }
  .buzz-launcher.is-bubble-visible .buzz-bubble {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mascot */
  .buzz-mascot-wrap {
    display: block;
    width: 120px;
    height: 120px;
    filter: drop-shadow(0 8px 10px rgba(61, 30, 109, 0.22));
    transition: transform 200ms var(--ease-soft);
    transform-origin: center bottom;
  }
  .buzz-launcher:hover .buzz-mascot-wrap,
  .buzz-launcher:focus-visible .buzz-mascot-wrap {
    transform: rotate(-4deg) translateY(-4px);
  }
  .buzz-mascot {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  /* Pill */
  .buzz-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--plum);
    color: var(--cream);
    padding: 9px 18px;
    border-radius: var(--r-pill);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.875rem;
    box-shadow: var(--shadow);
    animation: buzz-pulse 8s ease-in-out infinite;
    transform-origin: center;
    white-space: nowrap;
  }
  .buzz-pill svg { flex-shrink: 0; }
  .buzz-pill__arrow {
    display: inline-block;
    transition: transform 200ms var(--ease-soft);
  }
  .buzz-launcher:hover .buzz-pill__arrow,
  .buzz-launcher:focus-visible .buzz-pill__arrow {
    transform: translateX(3px);
  }

  @keyframes buzz-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.03); }
  }

  /* Collapsed (40px) */
  .buzz-launcher.is-collapsed .buzz-bubble,
  .buzz-launcher.is-collapsed .buzz-pill {
    display: none;
  }
  .buzz-launcher.is-collapsed .buzz-mascot-wrap {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: var(--cream);
    border: 2px solid var(--plum);
    padding: 2px;
    box-shadow: var(--shadow-lift);
    filter: none;
  }
  .buzz-launcher.is-collapsed:hover .buzz-mascot-wrap,
  .buzz-launcher.is-collapsed:focus-visible .buzz-mascot-wrap {
    transform: rotate(-6deg) translateY(-2px) scale(1.05);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .buzz-launcher {
      right: 16px;
      bottom: 16px;
      gap: 6px;
    }
    .buzz-mascot-wrap {
      width: 80px;
      height: 80px;
    }
    .buzz-bubble {
      font-size: 0.8125rem;
      max-width: 150px;
      padding: 10px 14px;
    }
    .buzz-pill {
      font-size: 0.8125rem;
      padding: 7px 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .buzz-launcher,
    .buzz-bubble,
    .buzz-mascot-wrap,
    .buzz-pill,
    .buzz-pill__arrow {
      transition: opacity 200ms linear !important;
      animation: none !important;
    }
    .buzz-launcher.is-hidden { transform: none; }
    .buzz-launcher:hover .buzz-mascot-wrap,
    .buzz-launcher:focus-visible .buzz-mascot-wrap {
      transform: none;
    }
  }
</style>
